{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: Development",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "console": "integratedTerminal",
      "env": {
        "APP_ENV": "development"
      }
    },
    {
      "name": "FastAPI: Production",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "console": "integratedTerminal",
      "env": {
        "APP_ENV": "production"
      }
    }
  ]
}
