### --- Python Core --- ###
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

### --- Environments --- ###
# Local virtual environments (should never be committed)
.venv/
env/
venv/
ENV/

### --- Environment Variables --- ###
# Private configuration and secrets
.env*
!.env.example

### --- VS Code --- ###
# Ignore all VS Code settings...
.vscode/*
# ...BUT keep the launch configuration as requested
!.vscode/launch.json

### --- Tools & Linting --- ###
# Cache directories for various Python tools
.pytest_cache/
.ruff_cache/
.mypy_cache/

### --- Distribution / Packaging --- ###
# Build artifacts
dist/
build/
*.egg-info/